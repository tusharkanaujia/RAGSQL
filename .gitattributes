# Normalize line endings: store LF in the repo, check out LF everywhere.
* text=auto eol=lf

# Explicit text types (belt-and-braces)
*.py    text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.env.example text eol=lf

# Binary types (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.parquet binary
*.xlsx  binary
