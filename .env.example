# Copy to .env and fill in. .env is gitignored.

# SQL Server connection (Windows auth shown; swap to UID/PWD if needed)
LBS_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=YOUR_SERVER;DATABASE=SputnikCube;Trusted_Connection=yes;

# Local LLM (optional — agent falls back to template narration if absent)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1

# Neo4j (optional — multi-hop relational questions). Empty password = disabled.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
